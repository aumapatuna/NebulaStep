<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_main"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome to NebulaStep!"
        android:textColor="@color/text_bright"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textAlignment="center"
        android:layout_marginBottom="16dp"/>
        
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Let's quickly set up your fitness profile so we can track you properly."
        android:textColor="@color/text_muted"
        android:textSize="16sp"
        android:textAlignment="center"
        android:layout_marginBottom="48dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Body Weight (kg)"
        android:textColor="@color/nebula_primary"
        android:textSize="18sp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/et_setup_weight"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="numberDecimal"
        android:hint="e.g. 70"
        android:textColor="@color/text_bright"
        android:textColorHint="#555555"
        android:background="#222222"
        android:padding="16dp"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Daily Step Goal"
        android:textColor="@color/nebula_primary"
        android:textSize="18sp"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/et_setup_goal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:hint="e.g. 10000"
        android:textColor="@color/text_bright"
        android:textColorHint="#555555"
        android:background="#222222"
        android:padding="16dp"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btn_setup_finish"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Finish Setup &amp; Start Walking"
        android:backgroundTint="@color/nebula_accent"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:padding="16dp"/>

</LinearLayout>
